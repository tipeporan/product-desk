# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Atlassian (get API token at https://id.atlassian.com/manage-profile/security/api-tokens)
ATLASSIAN_BASE_URL=https://yourcompany.atlassian.net
ATLASSIAN_EMAIL=your@email.com
ATLASSIAN_API_TOKEN=your_atlassian_api_token_here

# Google Docs — no env vars needed.
# Place credentials.json (OAuth2 Desktop client) next to this script.
# token.json is created automatically on first run.
